---
import type { FooterLink, SiteContent } from "../types/content";
import { withBase } from "@lib/paths";

interface Props {
  profile: SiteContent["profile"];
  links: FooterLink[];
}

const { profile, links } = Astro.props;
---

<footer class="site-footer">
  <div>
    <p class="footer-kicker">Document archive</p>
    <p>{profile.name} · {profile.email}</p>
  </div>
  <ul class="footer-links" aria-label="Contact links">
    {links.map((link) => (
      <li><a href={withBase(link.href)}>{link.label}</a></li>
    ))}
  </ul>
</footer>
