---
import { toRelativeUrl } from "@lib/paths";

interface Props {
  imagePath?: string;
  label: string;
  caption?: string;
  currentPath: string;
}

const { imagePath = "", label, caption, currentPath } = Astro.props;
---

{imagePath ? (
  <figure class="image-frame">
    <div class="image-visual">
      <img class="archive-image" src={toRelativeUrl(currentPath, imagePath)} alt={label} loading="lazy" data-fallback-image />
    </div>
    {caption && <figcaption class="image-caption">{caption}</figcaption>}
  </figure>
) : null}
