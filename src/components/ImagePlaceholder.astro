---
interface Props {
  imagePath?: string;
  label: string;
  caption?: string;
}

const { imagePath = "", label, caption } = Astro.props;
---

{imagePath ? (
  <figure class="image-frame">
    <div class="image-visual">
      <img class="archive-image" src={imagePath} alt={label} loading="lazy" data-fallback-image />
    </div>
    {caption && <figcaption class="image-caption">{caption}</figcaption>}
  </figure>
) : null}
