---
import type { NavigationLink, SiteContent } from "../types/content";

interface Props {
  links: NavigationLink[];
  profile: SiteContent["profile"];
  currentPath: string;
}

const { links, profile, currentPath } = Astro.props;

const isActiveLink = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<header class="navigation-frame">
  <nav class="navigation" aria-label="Primary navigation">
    <a class="brand-mark" href="/" aria-label={`${profile.name} home`}>
      <span class="brand-logo-frame">
        <img class="brand-logo" src="/logo.png" alt="" loading="eager" data-logo-image />
        <span class="brand-monogram">{profile.name.slice(0, 1)}</span>
      </span>
      <span class="brand-text">
        <strong>{profile.name}</strong>
        <small>{profile.professional_identity}</small>
      </span>
    </a>
    <div class="navigation-links">
      {links.map((link) => (
        <a href={link.href} class:list={["nav-link", { "is-active": isActiveLink(link.href) }]} aria-current={isActiveLink(link.href) ? "page" : undefined}>
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>
